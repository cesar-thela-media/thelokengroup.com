# Normalize line endings to LF on commit (cross-platform consistency)
* text=auto eol=lf
*.tsx text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.mjs text eol=lf
*.js text eol=lf

# Binaries
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.svg text eol=lf
